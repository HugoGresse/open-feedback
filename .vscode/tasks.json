{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start:local",
            "command": "npm",
            "args": ["run", "start:local"]
        },
        {
            "label": "test:functions",
            "command": "npm",
            "options": {
                "cwd": "${workspaceFolder}/functions"
            },
            "args": ["run", "test"]
        },
        {
            "label": "serve:functions",
            "command": "npm",
            "options": {
                "cwd": "${workspaceFolder}/functions"
            },
            "args": ["run", "serve"]
        }
    ]
}
